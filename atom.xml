---
layout: null
---
<?xml version="1.0" encoding="utf-8"?>
{% assign now_epoch = site.time | date: "%s" %}
{% assign feed_entries = site.posts | sort: "date" | reverse %}
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <link href="{{ site.url }}{{ site.baseurl }}/atom.xml" rel="self" />
  <link href="{{ site.url }}{{ site.baseurl }}/" rel="alternate" />
  <id>{{ site.url }}{{ site.baseurl }}/</id>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  {% for page in feed_entries %}
  {% assign page_epoch = page.date | date: "%s" %}
  {% if page.url contains '/posts/' and page_epoch <= now_epoch %}
  <entry>
    <title>{{ page.title | xml_escape }}</title>
    <link href="{{ site.url }}{{ site.baseurl }}{{ page.url }}" rel="alternate" />
    <id>{{ site.url }}{{ site.baseurl }}{{ page.url }}</id>
    <published>{{ page.date | date_to_xmlschema }}</published>
    <updated>{{ page.date | date_to_xmlschema }}</updated>
    <summary>{{ page.description | default: page.excerpt | strip_html | xml_escape }}</summary>
    <content type="html" xml:base="{{ site.url }}{{ site.baseurl }}{{ page.url }}">{{ page.content | markdownify | xml_escape }}</content>
  </entry>
  {% endif %}
  {% endfor %}
</feed>
